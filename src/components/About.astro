---
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)

const steps = [
  {
    step: 1,
    title: t('about.step1.title'),
    model: 'Gemini 1.5 Pro',
    description: t('about.step1.description'),
    accentColor: 'var(--accent-from)',
  },
  {
    step: 2,
    title: t('about.step2.title'),
    model: 'Claude 3.5 Sonnet',
    description: t('about.step2.description'),
    accentColor: 'var(--tag-violet)',
  },
  {
    step: 3,
    title: t('about.step3.title'),
    model: 'Claude CLI',
    description: t('about.step3.description'),
    accentColor: 'var(--accent-to)',
  },
]
---

<section>
  <h2 class="text-xl font-semibold mb-2 flex items-center gap-2" style="color: var(--text-primary);">
    <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
    {t('about.heading')}
  </h2>
  <p class="text-sm leading-relaxed mb-8" style="color: var(--text-secondary);">
    {t('about.bio')}
  </p>

  <h3 class="text-sm font-mono uppercase tracking-widest mb-5" style="color: var(--text-secondary);">{t('about.workflow.heading')}</h3>

  <div class="flex flex-col md:flex-row items-stretch gap-2">
    {steps.map((step, index) => (
      <Fragment>
        <div
          class="flex-1 font-mono rounded-lg p-4"
          style={`border-left: 2px solid ${step.accentColor}; background: color-mix(in srgb, ${step.accentColor} 10%, transparent);`}
        >
          <div class="text-xs mb-1.5" style={`color: ${step.accentColor};`}>
            {t('about.step.label')} {step.step < 10 ? `0${step.step}` : step.step}
          </div>
          <div class="text-sm font-semibold mb-1 leading-snug" style="color: var(--text-primary);">{step.title}</div>
          <div class="text-xs mb-2" style={`color: ${step.accentColor};`}>{step.model}</div>
          <div class="text-xs leading-relaxed font-sans" style="color: var(--text-secondary);">{step.description}</div>
        </div>
        {index < steps.length - 1 && (
          <div class="flex items-center justify-center md:px-1 py-1 md:py-0" aria-hidden="true">
            <span class="font-mono text-lg select-none md:[writing-mode:horizontal-tb] [writing-mode:vertical-lr] md:rotate-0 rotate-90" style="color: var(--tag-muted);">
              →
            </span>
          </div>
        )}
      </Fragment>
    ))}
  </div>
</section>
