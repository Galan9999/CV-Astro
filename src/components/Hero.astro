---
interface Props {
  meta: {
    name:     string
    role:     string
    location: string
    email:    string
    github:   string
    linkedin: string
  }
}

const { meta } = Astro.props

const links = [
  { href: meta.github,                label: 'GitHub'   },
  { href: `https://${meta.linkedin}`, label: 'LinkedIn' },
  { href: `mailto:${meta.email}`,     label: 'Email'    },
].filter(l => l.href && !l.href.includes('undefined'))
---

<section class="mb-16" aria-label="Introduction">
  <div class="flex flex-col-reverse md:flex-row md:items-center gap-6 mb-6">
    <div class="flex-1">
      <h1 class="text-4xl font-bold mb-2 tracking-tight" style="color: var(--text-primary);">{meta.name}</h1>
      <p class="text-lg font-semibold" style="color: var(--accent-from);">{meta.role}</p>
    </div>

    <div class="relative w-32 h-32 md:w-40 md:h-40 shrink-0">
      <img
        src="/images/profile.jpg"
        alt="Foto de perfil"
        width="160"
        height="160"
        loading="eager"
        class="profile-img rounded-2xl aspect-square object-cover w-full h-full"
      />
    </div>
  </div>

  <p class="leading-relaxed mb-5 max-w-xl" style="color: var(--text-secondary);">
    Building performant, accessible web applications with modern tooling and a focus on developer experience.
  </p>

  <div class="flex items-center gap-1.5 text-sm mb-8" style="color: var(--text-secondary);">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
      <circle cx="12" cy="10" r="3"/>
    </svg>
    <span>{meta.location}</span>
  </div>

  <nav class="flex flex-wrap gap-3" aria-label="Contact links">
    {links.map(link => (
      <a
        href={link.href}
        class="social-link inline-flex items-center px-4 py-2 text-sm transition-all duration-200"
        target={link.href.startsWith('mailto:') ? undefined : '_blank'}
        rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
        style="border: var(--border-width) solid var(--border); background: var(--bg-surface); color: var(--text-secondary); border-radius: var(--radius); text-decoration: none;"
      >
        {link.label}
      </a>
    ))}
  </nav>
</section>

<style>
  .profile-img {
    border: 2px solid color-mix(in srgb, var(--border) 60%, transparent);
    box-shadow: var(--shadow);
    filter: grayscale(100%);
    transition: filter 500ms ease, border-color 500ms ease, box-shadow 500ms ease;
  }
  .profile-img:hover {
    filter: grayscale(0%) drop-shadow(0 0 8px var(--glow-accent));
    border-color: var(--accent-from);
    box-shadow: var(--shadow-hover);
  }

  .social-link:hover,
  .social-link:focus-visible {
    color: var(--accent-from);
    border-color: var(--accent-from);
  }

  @media (prefers-reduced-motion: reduce) {
    .profile-img { transition: none; }
  }

  @media print {
    .profile-img { filter: none !important; }
    .social-link::after { content: " (" attr(href) ")"; }
  }
</style>
