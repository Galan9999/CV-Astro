---
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)

const tagColor: Record<string, string> = {
  performance:  'var(--accent-to)',
  architecture: 'var(--accent-from)',
  tooling:      'var(--tag-violet)',
}

const decisions = [
  { title: t('log.d1.title'), why: t('log.d1.why'), whyNot: t('log.d1.why_not'), tag: 'performance'  },
  { title: t('log.d2.title'), why: t('log.d2.why'), whyNot: t('log.d2.why_not'), tag: 'architecture' },
  { title: t('log.d3.title'), why: t('log.d3.why'), whyNot: t('log.d3.why_not'), tag: 'tooling'      },
  { title: t('log.d4.title'), why: t('log.d4.why'), whyNot: t('log.d4.why_not'), tag: 'performance'  },
]
---

<section class="mb-16" aria-label="Engineering decisions log">
  <div class="mb-6">
    <h2
      class="text-xl font-semibold mb-2 flex items-center gap-2"
      style="color: var(--text-primary);"
    >
      <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
      {t('log.heading')}
    </h2>
    <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
      {t('log.intro')}
    </p>
  </div>

  <div class="space-y-4">
    {decisions.map(d => (
      <article
        class="rounded-lg p-5 border"
        style="background: var(--bg-surface); border-color: var(--border);"
        data-tech-tag={d.tag}
      >
        <span
          class="inline-block text-xs font-mono px-2 py-0.5 rounded mb-3"
          style={`background: color-mix(in srgb, ${tagColor[d.tag]} 15%, transparent); color: ${tagColor[d.tag]};`}
        >
          {d.tag}
        </span>

        <h3 class="text-base font-semibold mb-2" style="color: var(--text-primary);">
          {d.title}
        </h3>

        <p class="text-sm leading-relaxed mb-3" style="color: var(--text-secondary);">
          {d.why}
        </p>

        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
          <strong style="color: var(--text-primary);">{t('log.why_not')}</strong>{' '}
          {d.whyNot}
        </p>
      </article>
    ))}
  </div>
</section>
