---
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
interface Props { label?: string; lang?: Lang }
const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)

const themes = [
  { id: 'sleek',         label: t('theme.sleek.label'),         icon: '◐' },
  { id: 'neo-brutalism', label: t('theme.neo-brutalism.label'), icon: '■' },
  { id: 'high-contrast', label: t('theme.high-contrast.label'), icon: '◉' },
] satisfies { id: string; label: string; icon: string }[]
---

<nav aria-label={t('theme.picker.label')} data-lang={lang} style="display: flex; gap: 8px; align-items: center;">
  {themes.map(t => (
    <button
      data-theme-btn={t.id}
      aria-pressed="false"
      style={`cursor: pointer; padding: 6px 14px; border: var(--border-width) solid var(--border); background: transparent; color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px; border-radius: var(--radius);`}
    >
      {t.icon} {t.label}
    </button>
  ))}
</nav>
<div id="theme-live" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<script>
  const STORAGE_KEY = 'cv-theme'
  const DEFAULT     = 'sleek'

  const themes = ['sleek', 'neo-brutalism', 'high-contrast'] as const
  type Theme = typeof themes[number]

  const labels: Record<Theme, string> = {
    'sleek':          'Sleek',
    'neo-brutalism':  'Neo-Brutalism',
    'high-contrast':  'High Contrast',
  }

  function applyTheme(theme: Theme) {
    document.documentElement.setAttribute('data-theme', theme)
    localStorage.setItem(STORAGE_KEY, theme)

    document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]')
      .forEach(btn => {
        const active = btn.dataset.themeBtn === theme
        btn.setAttribute('aria-pressed', String(active))
        btn.style.color       = active ? 'var(--text-primary)' : 'var(--text-secondary)'
        btn.style.borderColor = active ? 'var(--border-hover)' : 'var(--border)'
        btn.style.background  = active ? 'var(--bg-surface)' : 'transparent'
      })

    const live = document.getElementById('theme-live')
    if (live) {
      const lang = document.querySelector('[data-lang]')?.getAttribute('data-lang') ?? 'es'
      const announcements: Record<string, string> = {
        es: `Tema "${labels[theme]}" activado`,
        en: `Theme "${labels[theme]}" activated`,
        fr: `Thème "${labels[theme]}" activé`,
        ca: `Tema "${labels[theme]}" activat`,
      }
      live.textContent = announcements[lang] ?? announcements['es']
    }
  }

  const saved = localStorage.getItem(STORAGE_KEY) as Theme | null
  const initial = (saved && themes.includes(saved)) ? saved : DEFAULT
  applyTheme(initial)

  document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]')
    .forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.themeBtn as Theme
        if (themes.includes(t)) applyTheme(t)
      })
    })

  ;(window as any).setTheme = (t: string) => {
    if (themes.includes(t as Theme)) applyTheme(t as Theme)
    else console.warn(`[ThemeOrchestrator] unknown theme: "${t}". Options: ${themes.join(', ')}`)
  }
</script>
