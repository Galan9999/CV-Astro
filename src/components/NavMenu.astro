---
import { languages, defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import ThemeOrchestrator from './ThemeOrchestrator.astro';

interface Props {
  lang?: Lang;
  currentPath: string;
}

const { lang = defaultLang, currentPath } = Astro.props;
const t = useTranslations(lang);
const langs = Object.keys(languages) as Lang[];

const flags: Record<Lang, string> = {
  es: '🇪🇸',
  en: '🇬🇧',
  fr: '🇫🇷',
  ca: '🏴󠁥󠁳󠁣󠁴󠁿',
};

const sections = [
  { href: '#stack',       label: t('section.stack.heading') },
  { href: '#experiencia', label: t('nav.experience')        },
  { href: '#proceso',     label: t('ai.heading')            },
  { href: '#log',         label: t('log.heading')           },
  { href: '#about',       label: t('about.heading')         },
  { href: '#contacto',    label: t('contact.heading')       },
];
---

<header id="site-header" class="nav-header">

  <nav aria-label={t('lang.picker.label')} class="nav-inner">

    <a href="#main-content" class="nav-name" aria-label="Ir al inicio">
      Carles Galán
    </a>

    <ul class="nav-sections" role="list">
      {sections.map(s => (
        <li>
          <a href={s.href} class="nav-link">{s.label}</a>
        </li>
      ))}
    </ul>

    <div class="nav-controls">

      <ul class="nav-flags" role="list" aria-label={t('lang.picker.label')}>
        {langs.map(l => (
          <li>
            <a
              href={`/${l}${currentPath}`}
              aria-label={t(`lang.${l}` as any)}
              aria-current={l === lang ? 'true' : undefined}
              class={`nav-flag ${l === lang ? 'nav-flag--active' : ''}`}
            >
              {flags[l]}
            </a>
          </li>
        ))}
      </ul>

      <ThemeOrchestrator lang={lang} />

      <button
        id="menu-btn"
        class="nav-hamburger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        type="button"
      >
        <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" hidden aria-hidden="true">
          <line x1="18" y1="6"  x2="6" y2="18"/>
          <line x1="6"  y1="6"  x2="18" y2="18"/>
        </svg>
      </button>

    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" hidden aria-label="Menú de navegación">

    <section class="mobile-section">
      <p class="mobile-label">{t('nav.experience').toUpperCase()}</p>
      <ul role="list" class="mobile-links">
        {sections.map(s => (
          <li>
            <a href={s.href} class="mobile-link">{s.label}</a>
          </li>
        ))}
      </ul>
    </section>

    <hr class="mobile-divider" />

    <section class="mobile-section">
      <p class="mobile-label">{t('lang.picker.label').toUpperCase()}</p>
      <ul role="list" class="mobile-flags">
        {langs.map(l => (
          <li>
            <a
              href={`/${l}${currentPath}`}
              aria-label={t(`lang.${l}` as any)}
              aria-current={l === lang ? 'true' : undefined}
              class={`mobile-flag-item ${l === lang ? 'mobile-flag-item--active' : ''}`}
            >
              <span class="mobile-flag-emoji">{flags[l]}</span>
              <span class="mobile-flag-code">{l.toUpperCase()}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </div>

</header>

<script>
  const btn   = document.getElementById('menu-btn') as HTMLButtonElement | null;
  const menu  = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconO = document.getElementById('icon-open')  as SVGElement | null;
  const iconC = document.getElementById('icon-close') as SVGElement | null;

  function openMenu() {
    if (!menu || !btn) return;
    menu.hidden = false;
    btn.setAttribute('aria-expanded', 'true');
    if (iconO) iconO.hidden = true;
    if (iconC) iconC.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu || !btn) return;
    menu.hidden = true;
    btn.setAttribute('aria-expanded', 'false');
    if (iconO) iconO.hidden = false;
    if (iconC) iconC.hidden = true;
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    menu?.hidden ? openMenu() : closeMenu();
  });

  menu?.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.hidden) closeMenu();
  });
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: var(--border-width) solid var(--border);
    background: var(--bg-base);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 12px 24px;
    max-width: 72rem;
    margin: 0 auto;
  }

  .nav-name {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-sections {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-sections { display: flex; }
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .nav-link:hover { color: var(--text-primary); }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav-flags {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-flags { display: flex; }
  }

  .nav-flag {
    font-size: 1.125rem;
    line-height: 1;
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .nav-flag:hover { opacity: 0.8; transform: scale(1.15); }
  .nav-flag--active { opacity: 1; }

  .nav-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 6px;
    transition: color 150ms, border-color 150ms;
  }

  .nav-hamburger:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  @media (min-width: 768px) {
    .nav-hamburger { display: none; }
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 49px;
    z-index: 99;
    background: var(--bg-base);
    overflow-y: auto;
    padding: 1.5rem 1.5rem 3rem;
  }

  .mobile-section { margin-bottom: 1.5rem; }

  .mobile-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    margin: 0 0 0.75rem;
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-link {
    display: block;
    padding: 0.875rem 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: var(--border-width) solid var(--border);
    transition: color 150ms, padding-left 150ms;
  }

  .mobile-link:hover {
    color: var(--accent-from);
    padding-left: 0.5rem;
  }

  .mobile-divider {
    border: none;
    border-top: var(--border-width) solid var(--border);
    margin: 1.5rem 0;
  }

  .mobile-flags {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-flag-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 0.5rem;
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
  }

  .mobile-flag-item:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  .mobile-flag-item--active {
    border-color: var(--accent-from);
    background: var(--bg-surface);
  }

  .mobile-flag-emoji { font-size: 1.5rem; line-height: 1; }

  .mobile-flag-code {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-secondary);
  }

  .mobile-flag-item--active .mobile-flag-code {
    color: var(--accent-from);
  }

  @media print {
    .nav-header { display: none !important; }
  }
</style>
