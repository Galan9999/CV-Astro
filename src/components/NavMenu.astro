---
import { languages, defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
  currentPath: string;
}

const { lang = defaultLang, currentPath } = Astro.props;
const t = useTranslations(lang);
const langs = Object.keys(languages) as Lang[];

const flags: Record<Lang, string> = {
  es: '🇪🇸',
  en: '🇬🇧',
  fr: '🇫🇷',
  ca: 'CAT',
};

const sections = [
  { href: '#stack',       label: t('section.stack.heading'), short: t('nav.stack')      },
  { href: '#experiencia', label: t('nav.experience'),        short: t('nav.experience') },
  { href: '#proceso',     label: t('ai.heading'),            short: t('nav.proceso')    },
  { href: '#log',         label: t('log.heading'),           short: t('nav.log')        },
  { href: '#about',       label: t('about.heading'),         short: t('nav.about')      },
  { href: '#contacto',    label: t('contact.heading'),       short: t('nav.contact')    },
];
---

<header id="site-header" class="nav-header">

  <nav aria-label={t('lang.picker.label')} class="nav-inner">

    <a href="#main-content" class="nav-name" aria-label="Ir al inicio">
      Carles Galán
    </a>

    <ul class="nav-sections" role="list">
      {sections.map(s => (
        <li>
          <a href={s.href} class="nav-link">{s.short}</a>
        </li>
      ))}
    </ul>

    <div class="nav-controls">

      <ul class="nav-flags" role="list" aria-label={t('lang.picker.label')}>
        {langs.map(l => (
          <li>
            <a
              href={`/${l}${currentPath}`}
              aria-label={t(`lang.${l}` as any)}
              aria-current={l === lang ? 'true' : undefined}
              class={`nav-flag ${l === lang ? 'nav-flag--active' : ''}`}
            >
              <span class={l === 'ca' ? 'nav-flag--text' : ''}>{flags[l]}</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="theme-dropdown" id="theme-dropdown-wrapper">
        <button
          id="theme-toggle-btn"
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="theme-dropdown-menu"
          aria-label={t('theme.picker.label')}
          class="theme-toggle-btn"
        >
          <span id="theme-current-icon" aria-hidden="true">◑</span>
          <span class="theme-toggle-label">{t('nav.theme')}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>

        <ul
          id="theme-dropdown-menu"
          role="menu"
          aria-label={t('theme.picker.label')}
          class="theme-menu"
          hidden
        >
          <li role="none">
            <button role="menuitem" data-theme-btn="sleek" class="theme-menu-item" type="button">
              ◐ {t('theme.sleek.label')}
            </button>
          </li>
          <li role="none">
            <button role="menuitem" data-theme-btn="neo-brutalism" class="theme-menu-item" type="button">
              ■ {t('theme.neo-brutalism.label')}
            </button>
          </li>
          <li role="none">
            <button role="menuitem" data-theme-btn="high-contrast" class="theme-menu-item" type="button">
              ◉ {t('theme.high-contrast.label')}
            </button>
          </li>
        </ul>
      </div>

      <button
        id="menu-btn"
        class="nav-hamburger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        type="button"
      >
        <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" hidden aria-hidden="true">
          <line x1="18" y1="6"  x2="6" y2="18"/>
          <line x1="6"  y1="6"  x2="18" y2="18"/>
        </svg>
      </button>

    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" hidden aria-label="Menú de navegación">

    <section class="mobile-section">
      <p class="mobile-label">{t('nav.experience').toUpperCase()}</p>
      <ul role="list" class="mobile-links">
        {sections.map(s => (
          <li>
            <a href={s.href} class="mobile-link">{s.label}</a>
          </li>
        ))}
      </ul>
    </section>

    <hr class="mobile-divider" />

    <section class="mobile-section">
      <p class="mobile-label">{t('lang.picker.label').toUpperCase()}</p>
      <ul role="list" class="mobile-flags">
        {langs.map(l => (
          <li>
            <a
              href={`/${l}${currentPath}`}
              aria-label={t(`lang.${l}` as any)}
              aria-current={l === lang ? 'true' : undefined}
              class={`mobile-flag-item ${l === lang ? 'mobile-flag-item--active' : ''}`}
            >
              <span class={l === 'ca' ? 'mobile-flag--text' : 'mobile-flag-emoji'}>{flags[l]}</span>
              <span class="mobile-flag-code">{l.toUpperCase()}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </div>

</header>

<script>
  const btn   = document.getElementById('menu-btn') as HTMLButtonElement | null;
  const menu  = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconO = document.getElementById('icon-open')  as SVGElement | null;
  const iconC = document.getElementById('icon-close') as SVGElement | null;

  function openMenu() {
    if (!menu || !btn) return;
    menu.hidden = false;
    btn.setAttribute('aria-expanded', 'true');
    if (iconO) iconO.hidden = true;
    if (iconC) iconC.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu || !btn) return;
    menu.hidden = true;
    btn.setAttribute('aria-expanded', 'false');
    if (iconO) iconO.hidden = false;
    if (iconC) iconC.hidden = true;
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    menu?.hidden ? openMenu() : closeMenu();
  });

  menu?.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.hidden) closeMenu();
  });

  const header = document.getElementById('site-header');
  if (header) {
    document.documentElement.style.setProperty(
      '--nav-height', header.offsetHeight + 'px'
    );
  }

  const themeBtn    = document.getElementById('theme-toggle-btn') as HTMLButtonElement | null;
  const themeMenu   = document.getElementById('theme-dropdown-menu') as HTMLElement | null;
  const currentIcon = document.getElementById('theme-current-icon') as HTMLElement | null;

  const themeIcons: Record<string, string> = {
    'sleek':          '◐',
    'neo-brutalism':  '■',
    'high-contrast':  '◉',
  };

  function openThemeMenu() {
    if (!themeMenu || !themeBtn) return;
    themeMenu.hidden = false;
    themeBtn.setAttribute('aria-expanded', 'true');
  }

  function closeThemeMenu() {
    if (!themeMenu || !themeBtn) return;
    themeMenu.hidden = true;
    themeBtn.setAttribute('aria-expanded', 'false');
  }

  themeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    themeMenu?.hidden ? openThemeMenu() : closeThemeMenu();
  });

  document.addEventListener('click', () => closeThemeMenu());
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeThemeMenu();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const theme = btn.dataset.themeBtn ?? 'sleek';
      (window as any).setTheme?.(theme);
      if (currentIcon) currentIcon.textContent = themeIcons[theme] ?? '◐';
      document.querySelectorAll('[data-theme-btn]').forEach(b => {
        b.setAttribute('aria-checked', String(b === btn));
      });
      closeThemeMenu();
    });
  });

  const savedTheme = localStorage.getItem('cv-theme') ?? 'sleek';
  if (currentIcon) currentIcon.textContent = themeIcons[savedTheme] ?? '◐';
  document.querySelector(`[data-theme-btn="${savedTheme}"]`)
    ?.setAttribute('aria-checked', 'true');
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: var(--border-width) solid var(--border);
    background: var(--bg-base);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 12px 24px;
    max-width: 48rem;
    margin: 0 auto;
  }

  .nav-name {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-sections {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .nav-sections { display: flex; }
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .nav-link:hover { color: var(--text-primary); }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .nav-flags {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .nav-flags { display: flex; }
  }

  .nav-flag {
    font-size: 1.125rem;
    line-height: 1;
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .nav-flag:hover { opacity: 0.8; transform: scale(1.15); }
  .nav-flag--active { opacity: 1; }

  .nav-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 6px;
    transition: color 150ms, border-color 150ms;
  }

  .nav-hamburger:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  @media (min-width: 1024px) {
    .nav-hamburger { display: none; }
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    top: var(--nav-height, 49px);
    z-index: 99;
    background: var(--bg-base);
    overflow-y: auto;
    padding: 1rem 1.25rem 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .mobile-section { margin-bottom: 1.5rem; }

  .mobile-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    margin: 0 0 0.75rem;
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: var(--border-width) solid var(--border);
    text-align: center;
    transition: color 150ms;
  }

  .mobile-link:hover {
    color: var(--accent-from);
  }

  .mobile-divider {
    border: none;
    border-top: var(--border-width) solid var(--border);
    margin: 1.5rem 0;
  }

  .mobile-flags {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-flag-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.25rem;
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
  }

  .mobile-flag-item:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  .mobile-flag-item--active {
    border-color: var(--accent-from);
    background: var(--bg-surface);
  }

  .mobile-flag-emoji { font-size: 1.125rem; line-height: 1; }

  .mobile-flag-code {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-secondary);
  }

  .mobile-flag-item--active .mobile-flag-code {
    color: var(--accent-from);
  }

  @media print {
    .nav-header { display: none !important; }
  }

  .theme-dropdown {
    position: relative;
  }

  .theme-toggle-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 5px 10px;
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
    white-space: nowrap;
  }

  .theme-toggle-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  .theme-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    min-width: 160px;
    background: var(--bg-elevated);
    border: var(--border-width) solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-hover);
    padding: 4px;
    z-index: 200;
    list-style: none;
    margin: 0;
  }

  .theme-menu-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 8px 12px;
    background: transparent;
    border: none;
    border-radius: calc(var(--radius) - 4px);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    text-align: left;
    transition: background 150ms, color 150ms;
  }

  .theme-menu-item:hover {
    background: var(--bg-surface);
    color: var(--text-primary);
  }

  .theme-menu-item[aria-checked="true"] {
    color: var(--accent-from);
  }

  .nav-flag--text {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .mobile-flag--text {
    font-size: 0.875rem;
    font-family: var(--font-mono);
    font-weight: 700;
    line-height: 1.8;
  }

  .theme-toggle-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
  }
</style>
