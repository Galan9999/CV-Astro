---
import cvData from '../data/cv.json'
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)

type Skill = { skill: string; mastery: number; category: string }

const skills = cvData.skills_radar as Skill[]

const categoryColor: Record<string, string> = {
  frontend: 'var(--accent-from)',
  craft:    'var(--accent-to)',
  systems:  'var(--tag-violet)',
}

const sorted = [...skills].sort((a, b) => b.mastery - a.mastery)
const categoryLabel: Record<string, string> = {
  frontend: t('skills.category.frontend'),
  craft:    t('skills.category.craft'),
  systems:  t('skills.category.systems'),
}
---

<section class="mb-16" aria-label="Skills and mastery">
  <h2
    class="text-xl font-semibold mb-6 flex items-center gap-2"
    style="color: var(--text-primary);"
  >
    <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
    {t('skills.heading')}
  </h2>

  <div class="space-y-3">
    {sorted.map(s => (
      <div class="skill-row">
        <div class="flex justify-between text-sm mb-1.5">
          <span class="skill-label" style="color: var(--text-primary);">{s.skill}</span>
          <span class="font-mono text-xs" style="color: var(--text-secondary);">{s.mastery}%</span>
        </div>
        <div
          class="h-1.5 rounded-full overflow-hidden"
          style="background: var(--bg-elevated);"
        >
          <div
            role="progressbar"
            tabindex="0"
            aria-valuenow={s.mastery}
            aria-valuemin={0}
            aria-valuemax={100}
            aria-label={`${s.skill}: ${s.mastery}%`}
            class="skill-fill h-full rounded-full"
            style={`width: ${s.mastery}%; background: ${categoryColor[s.category] ?? 'var(--accent-from)'};`}
          />
        </div>
      </div>
    ))}
  </div>

  <div class="flex flex-wrap gap-4 mt-5" aria-label="Category legend">
    {Object.entries(categoryColor).map(([cat, color]) => (
      <span class="flex items-center gap-1.5 text-xs" style="color: var(--text-secondary);">
        <span
          class="w-2 h-2 rounded-full"
          style={`background: ${color};`}
          aria-hidden="true"
        />
        {categoryLabel[cat] ?? cat}
      </span>
    ))}
  </div>
</section>

<style>
  .skill-fill {
    transition: width 600ms ease,
                background-color 200ms ease,
                box-shadow 200ms ease;
  }

  .skill-row:hover .skill-fill,
  .skill-row:focus-within .skill-fill {
    background-color: var(--accent-from);
    box-shadow: 0 0 15px var(--glow-accent);
  }

  .skill-row:hover .skill-label,
  .skill-row:focus-within .skill-label {
    color: var(--text-primary);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-fill { transition: none; }
  }

  @media print {
    .skill-fill { display: none; }
  }
</style>
