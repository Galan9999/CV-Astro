---
interface Props {
  company:      string
  role:         string
  period:       { start: string; end: string }
  achievements: Array<{
    text:    string
    metric?: string
    tag?:    'performance' | 'rbac' | 'architecture' | 'testing' | 'security'
  }>
  tech:         string[]
}

const { company, role, period, achievements, tech } = Astro.props

const tagColors: Record<string, string> = {
  performance:  'var(--accent-to)',
  rbac:         'var(--tag-violet)',
  architecture: 'var(--accent-from)',
  testing:      'var(--tag-emerald)',
  security:     'var(--tag-amber)',
}
---

<article
  class="experience-card"
  style="border: var(--border-width) solid var(--border); background: var(--bg-surface); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); transition: border-color 200ms ease, box-shadow 200ms ease;"
>
  <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.25rem;">
    <div>
      <h3
        class="company-name"
        style="font-size: 1.125rem; font-weight: 600; color: var(--text-primary);"
      >
        {company}
      </h3>
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.125rem;">
        {role}
      </p>
    </div>
    <span
      style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--text-secondary); flex-shrink: 0; margin-left: 1rem; margin-top: 0.125rem;"
    >
      {period.start} — {period.end}
    </span>
  </div>

  <ul style="margin: 1rem 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.5rem;">
    {achievements.map(a => (
      <li style="border-left: var(--border-width) solid var(--border); padding-left: 0.75rem; font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6;">
        {a.text}
        {a.metric && (
          <span
            style={`font-family: var(--font-mono); font-size: 0.8125rem; color: ${a.tag ? tagColors[a.tag] : 'var(--text-mono)'}; margin-left: 0.5rem;`}
          >
            → {a.metric}
          </span>
        )}
      </li>
    ))}
  </ul>

  <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
    {tech.map(t => (
      <span
        style="font-family: var(--font-mono); font-size: 0.75rem; padding: 2px 8px; border-radius: var(--radius); background: var(--bg-elevated); color: var(--text-secondary);"
      >
        {t}
      </span>
    ))}
  </div>
</article>

<style>
  .experience-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-hover);
  }
  .experience-card:hover .company-name {
    background: linear-gradient(
      90deg,
      var(--accent-from),
      var(--accent-to)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  /* neo-brutalism: square bullet instead of left border */
  [data-theme="neo-brutalism"] .experience-card li {
    border-left: none;
    padding-left: 18px;
    position: relative;
  }
  [data-theme="neo-brutalism"] .experience-card li::before {
    content: '■';
    position: absolute;
    left: 0;
    font-size: 8px;
    top: 6px;
    color: var(--text-primary);
  }
  /* high-contrast: always show hover border */
  [data-theme="high-contrast"] .experience-card {
    border-color: var(--border);
  }
</style>
