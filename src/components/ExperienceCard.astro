---
import { type Lang } from '../i18n/ui';

interface Props {
  company:      string
  role:         string
  period:       string
  location:     string
  highlight:    string
  achievements: string[]
  stack:        string[]
  lang?:        Lang
}

const { company, role, period, location, highlight, achievements, stack } = Astro.props;
---

<article class="exp-card">
  <header class="card-header">
    <div class="card-meta">
      <h3 class="company-name">{company}</h3>
      <p class="role">{role}</p>
      <p class="location">{location}</p>
    </div>
    <time class="period">{period}</time>
  </header>

  <p class="highlight">{highlight}</p>

  <ul class="achievements" role="list">
    {achievements.map(item => <li>{item}</li>)}
  </ul>

  <div class="flex flex-wrap gap-2 mt-3">
    {stack.map(item => (
      <span
        data-stack-badge
        class="font-mono text-xs border border-neutral-700 bg-neutral-900 text-neutral-300 px-2 py-0.5 rounded"
      >
        {item}
      </span>
    ))}
  </div>
</article>

<style>
  .exp-card {
    border: var(--border-width) solid var(--border);
    background: var(--bg-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.5rem;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .exp-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-hover);
  }

  .exp-card:hover .company-name {
    background: linear-gradient(90deg, var(--accent-from), var(--accent-to));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .card-meta { flex: 1; min-width: 0; }

  .company-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .role {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    opacity: 0.7;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .highlight {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent-from);
    line-height: 1.6;
    border-left: 2px solid var(--accent-from);
    padding-left: 0.75rem;
    margin: 0.75rem 0;
  }

  .achievements {
    list-style: none;
    padding: 0;
    margin: 0 0 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .achievements li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .achievements li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-from);
    line-height: 1.6;
  }

  /* Neo-brutalism: square bullet */
  [data-theme="neo-brutalism"] .exp-card .achievements li::before {
    content: '■';
    font-size: 0.5rem;
    top: 0.45rem;
    line-height: 1;
  }

  /* Non-dark themes: override hardcoded badge colors */
  [data-theme="neo-brutalism"] .exp-card [data-stack-badge],
  [data-theme="high-contrast"] .exp-card [data-stack-badge] {
    background: var(--bg-elevated) !important;
    color: var(--text-primary) !important;
    border-color: var(--border) !important;
  }

  /* ── Print ─────────────────────────────────────────────── */
  @media print {
    .exp-card {
      border: 0.5pt solid #ccc !important;
      background: white !important;
      box-shadow: none !important;
      padding: 8pt 0;
    }

    .company-name { font-size: 12pt !important; }

    .role,
    .location { color: #444 !important; opacity: 1 !important; }

    .period { color: #444 !important; }

    .highlight {
      color: #333 !important;
      border-left-color: #999 !important;
    }

    .achievements li { color: #333 !important; }

    .achievements li::before { color: #555 !important; }

    [data-stack-badge] {
      border: 0.5pt solid #999 !important;
      background: transparent !important;
      color: #333 !important;
    }
  }
</style>
