---
interface Props {
  company: string;
  role: string;
  period: { start: string; end: string };
  achievements: string[];
  tech: string[];
}

const { company, role, period, achievements, tech } = Astro.props;
---

<article class="border border-slate-800 bg-slate-900/50 rounded-xl p-6 group transition-all duration-300 hover:border-slate-700 hover:bg-slate-900/80">
  <div class="flex items-start justify-between mb-1">
    <h3 class="text-white font-semibold text-lg transition-all duration-300 group-hover:bg-gradient-to-r group-hover:from-indigo-400 group-hover:to-cyan-400 group-hover:bg-clip-text group-hover:text-transparent">
      {company}
    </h3>
    <span class="font-mono text-slate-500 text-sm shrink-0 ml-4 mt-0.5">
      {period.start} — {period.end}
    </span>
  </div>

  <p class="text-slate-400 text-sm mb-4">{role}</p>

  <ul class="mb-4 space-y-2">
    {achievements.map(achievement => (
      <li class="border-l-2 border-slate-700 pl-3 text-slate-300 text-sm leading-relaxed group-hover:border-indigo-500 transition-colors duration-300">
        {achievement}
      </li>
    ))}
  </ul>

  <div class="flex flex-wrap gap-1.5">
    {tech.map(item => (
      <span class="font-mono text-xs px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 group-hover:bg-indigo-950 group-hover:text-cyan-400 transition-all duration-300">
        {item}
      </span>
    ))}
  </div>
</article>
