---
interface Props {
  id:          string
  type:        'featured' | 'compact'
  company:     string
  role:        string
  period:      string
  description: string
  stack:       string[]
}

const { type, company, role, period, description, stack } = Astro.props

const isCompact     = type === 'compact'
const visibleStack  = isCompact ? stack.slice(0, 2) : stack
const extraCount    = isCompact ? Math.max(0, stack.length - 2) : 0
---

{isCompact ? (
  <article class="exp-card compact">
    <div class="card-header">
      <div>
        <h3 class="company-name compact-name">{company}</h3>
        <p class="role compact-role">{role}</p>
      </div>
      <span class="period compact-period">{period}</span>
    </div>
    <p class="desc compact-desc">{description}</p>
    <div class="stack-row">
      {visibleStack.map(t => <span class="tag">{t}</span>)}
      {extraCount > 0 && <span class="tag tag-extra">+{extraCount} más</span>}
    </div>
  </article>
) : (
  <article class="exp-card featured">
    <div class="card-header">
      <div>
        <h3 class="company-name">{company}</h3>
        <p class="role">{role}</p>
      </div>
      <span class="period">{period}</span>
    </div>
    <p class="desc featured-desc">{description}</p>
    <div class="stack-row">
      {stack.map(t => <span class="tag">{t}</span>)}
    </div>
  </article>
)}

<style>
  .exp-card {
    border: var(--border-width) solid var(--border);
    background: var(--bg-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .exp-card.featured { padding: 1.5rem; }
  .exp-card.compact  { padding: 1rem; }

  .exp-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-hover);
  }
  .exp-card:hover .company-name {
    background: linear-gradient(90deg, var(--accent-from), var(--accent-to));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .company-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .compact-name { font-size: 0.875rem; }

  .role {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.125rem;
  }
  .compact-role { font-size: 0.75rem; margin-top: 2px; }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    flex-shrink: 0;
    margin-left: 0.5rem;
    margin-top: 0.125rem;
    white-space: nowrap;
  }
  .compact-period { font-size: 0.75rem; }

  .desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .featured-desc {
    margin: 1rem 0;
    border-left: var(--border-width) solid var(--border);
    padding-left: 0.75rem;
  }
  .compact-desc {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin: 0.5rem 0 0.75rem;
  }

  .stack-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .featured .stack-row { gap: 0.375rem; }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: var(--radius);
    background: var(--bg-elevated);
    color: var(--text-secondary);
  }
  .compact .tag { font-size: 0.6875rem; padding: 2px 6px; }

  .tag-extra {
    background: color-mix(in srgb, var(--accent-from) 12%, transparent);
    color: var(--accent-from);
  }

  /* Neo-brutalism overrides */
  [data-theme="neo-brutalism"] .exp-card li {
    border-left: none;
    padding-left: 18px;
    position: relative;
  }
  [data-theme="neo-brutalism"] .exp-card li::before {
    content: '■';
    position: absolute;
    left: 0;
    font-size: 8px;
    top: 6px;
    color: var(--text-primary);
  }
</style>
