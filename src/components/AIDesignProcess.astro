---
import { defaultLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props
const t = useTranslations(lang)

const steps = [
  {
    tool:   'Gemini 1.5 Pro',
    role:   t('ai.step1.role'),
    detail: t('ai.step1.detail'),
    accent: 'var(--accent-from)',
  },
  {
    tool:   'Claude 3.5 Sonnet',
    role:   t('ai.step2.role'),
    detail: t('ai.step2.detail'),
    accent: 'var(--tag-violet)',
  },
  {
    tool:   'Claude CLI',
    role:   t('ai.step3.role'),
    detail: t('ai.step3.detail'),
    accent: 'var(--accent-to)',
  },
]
---

<section aria-labelledby="ai-design-heading" style="color: var(--text-primary);">
  <header style="margin-bottom: 2rem;">
    <h2
      id="ai-design-heading"
      style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;"
    >
      {t('ai.heading')}
    </h2>
    <p style="color: var(--text-secondary); line-height: 1.7; max-width: 60ch;">
      {t('ai.intro')}
    </p>
  </header>

  <div style="margin-bottom: 2.5rem;">
    <h3 style="font-size: 1rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem;">
      {t('ai.workflow.heading')}
    </h3>

    <ol style="list-style: none; padding: 0; margin: 0;">
      {steps.map((s, i) => (
        <li style="display: flex; gap: 1rem; align-items: flex-start;">
          <div style="display: flex; flex-direction: column; align-items: center; flex-shrink: 0;">
            <div style={`width: 32px; height: 32px; border-radius: 50%; background: ${s.accent}; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: var(--on-accent); font-family: var(--font-mono);`}>
              {i + 1}
            </div>
            {i < steps.length - 1 && (
              <div style="width: 2px; height: 40px; background: var(--border); margin-top: 4px;" aria-hidden="true" />
            )}
          </div>

          <div style={`padding-bottom: ${i < steps.length - 1 ? '1.5rem' : '0'};`}>
            <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.25rem;">
              <span style={`font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: ${s.accent};`}>
                {s.tool}
              </span>
              <span style="font-size: 13px; color: var(--text-secondary);">
                — {s.role}
              </span>
            </div>
            <p style="font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin: 0;">
              {s.detail}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <div
    style="border: var(--border-width) solid var(--border); border-radius: var(--radius); padding: 1.5rem; background: var(--bg-surface); margin-bottom: 1.5rem;"
  >
    <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem;">
      {t('ai.handoff.heading')}
    </h3>
    <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem;">
      {t('ai.handoff.p1')}
    </p>
    <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.7; margin: 0;">
      {t('ai.handoff.p2')}
    </p>
  </div>

  <p style="font-size: 13px; color: var(--text-secondary); font-family: var(--font-mono);">
    {t('ai.handoff.p3')}
  </p>
</section>
