---
import BaseLayout       from '@layouts/BaseLayout.astro';
import ExperienceCard   from '@components/ExperienceCard.astro';
import About            from '@components/About.astro';
import AIDesignProcess  from '@components/AIDesignProcess.astro';
import EngineeringLog   from '@components/EngineeringLog.astro';
import GitTree          from '@components/GitTree.astro';
import SkillsRadar      from '@components/SkillsRadar.astro';
import PrintButton      from '@components/PrintButton.astro';
import cvData from '@data/cv.json';

const { meta, stack, experience } = cvData;
const currentYear = new Date().getFullYear();
---

<BaseLayout title={`${meta.name} — ${meta.role}`} description={`CV of ${meta.name}, ${meta.role}`}>

  <div class="max-w-3xl mx-auto px-6 py-14">

    <section class="mb-16" aria-label="Introduction">
      <div class="flex items-center gap-6 mb-6">
        <div class="avatar flex-shrink-0">
          <img
            src="/images/profile.jpg"
            alt={`Portrait of ${meta.name}`}
            width="96"
            height="96"
            class="rounded-full grayscale transition-all duration-300"
            style="border: var(--border-width) solid var(--border); width: 96px; height: 96px; object-fit: cover;"
          />
        </div>
        <div>
          <h1 class="text-4xl font-bold mb-2 tracking-tight" style="color: var(--text-primary);">{meta.name}</h1>
          <p class="text-lg font-semibold" style="color: var(--accent-from);">{meta.role}</p>
        </div>
      </div>
      <p class="leading-relaxed mb-5 max-w-xl" style="color: var(--text-secondary);">
        Building performant, accessible web applications with modern tooling and a focus on developer experience.
      </p>

      <div class="flex items-center gap-1.5 text-sm mb-8" style="color: var(--text-secondary);">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>{meta.location}</span>
      </div>

      <nav class="flex flex-wrap gap-3" aria-label="Contact links">
        {[
          { href: meta.github,                label: 'GitHub'   },
          { href: `https://${meta.linkedin}`, label: 'LinkedIn' },
          { href: `mailto:${meta.email}`,     label: 'Email'    },
        ].filter(l => l.href && !l.href.includes('undefined')).map(link => (
          <a
            href={link.href}
            class="social-link inline-flex items-center px-4 py-2 text-sm transition-all duration-200"
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            style="border: var(--border-width) solid var(--border); background: var(--bg-surface); color: var(--text-secondary); border-radius: var(--radius); text-decoration: none;"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </section>

    <SkillsRadar />

    <section class="mb-16" aria-label="Technology stack">
      <h2 class="text-xl font-semibold mb-4 flex items-center gap-2" style="color: var(--text-primary);">
        <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
        Stack
      </h2>
      <div class="flex flex-wrap gap-2">
        {stack.map(item => (
          <span
            class="font-mono text-xs px-3 py-1.5 rounded-md cursor-default transition-all duration-200"
            style="background: var(--bg-surface); border: var(--border-width) solid var(--border); color: var(--text-secondary);"
            data-tech-tag
          >
            {item}
          </span>
        ))}
      </div>
    </section>

    <section class="mb-16" aria-label="Work experience">
      <h2 class="text-xl font-semibold mb-6 flex items-center gap-2" style="color: var(--text-primary);">
        <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
        Experience
      </h2>
      <div class="space-y-4">
        {experience.map(exp => (
          <ExperienceCard
            company={exp.company}
            role={exp.role}
            period={exp.period}
            achievements={exp.achievements.map(text => ({ text }))}
            tech={exp.tech}
          />
        ))}
      </div>
    </section>

    <AIDesignProcess />

    <EngineeringLog />

    <GitTree />

    <div class="mb-16">
      <About />
    </div>

    <footer class="border-t pt-8" style="border-color: var(--border);" role="contentinfo">
      <p class="font-mono text-xs text-center" style="color: var(--text-secondary);">
        © {currentYear} {meta.name} · Built with Astro 4 + Tailwind CSS
      </p>
    </footer>

  </div>

  <PrintButton />

</BaseLayout>

<style>
  .avatar img {
    transition: filter 300ms ease, border-color 300ms ease;
    filter: grayscale(100%);
  }

  .avatar img:hover,
  .avatar img:focus-visible {
    filter: grayscale(0%) drop-shadow(0 0 8px var(--glow-accent));
    border-color: var(--accent-from);
  }

  .social-link:hover,
  .social-link:focus-visible {
    color: var(--accent-from);
    border-color: var(--accent-from);
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar img { transition: none; }
  }

  @media print {
    .avatar img { filter: none !important; }
    .social-link::after { content: " (" attr(href) ")"; }
  }
</style>
