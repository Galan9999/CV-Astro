---
import BaseLayout       from '@layouts/BaseLayout.astro';
import ExperienceCard   from '@components/ExperienceCard.astro';
import About            from '@components/About.astro';
import AIDesignProcess  from '@components/AIDesignProcess.astro';
import EngineeringLog   from '@components/EngineeringLog.astro';
import GitTree          from '@components/GitTree.astro';
import SkillsRadar      from '@components/SkillsRadar.astro';
import PrintButton      from '@components/PrintButton.astro';
import cvData from '@data/cv.json';

const { meta, stack, experience } = cvData;
const currentYear = new Date().getFullYear();
---

<BaseLayout title={`${meta.name} — ${meta.role}`} description={`CV of ${meta.name}, ${meta.role}`}>

  <div class="max-w-3xl mx-auto px-6 py-14">

    <section class="mb-16" aria-label="Introduction">
      <h1 class="text-4xl font-bold mb-2 tracking-tight" style="color: var(--text-primary);">{meta.name}</h1>
      <p class="text-lg font-semibold mb-4" style="color: var(--accent-from);">{meta.role}</p>
      <p class="leading-relaxed mb-5 max-w-xl" style="color: var(--text-secondary);">
        Building performant, accessible web applications with modern tooling and a focus on developer experience.
      </p>

      <div class="flex items-center gap-1.5 text-sm mb-8" style="color: var(--text-secondary);">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>{meta.location}</span>
      </div>

      <nav class="flex flex-wrap gap-3" aria-label="Contact links">
        <a
          href={meta.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-all duration-200"
          style="border: var(--border-width) solid var(--border); background: var(--bg-surface); color: var(--text-secondary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>

        <a
          href={`https://${meta.linkedin}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-all duration-200"
          style="border: var(--border-width) solid var(--border); background: var(--bg-surface); color: var(--text-secondary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>

        <a
          href={`mailto:${meta.email}`}
          aria-label={`Email ${meta.name}`}
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-all duration-200"
          style="border: var(--border-width) solid var(--border); background: var(--bg-surface); color: var(--text-secondary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          {meta.email}
        </a>
      </nav>
    </section>

    <SkillsRadar />

    <section class="mb-16" aria-label="Technology stack">
      <h2 class="text-xl font-semibold mb-4 flex items-center gap-2" style="color: var(--text-primary);">
        <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
        Stack
      </h2>
      <div class="flex flex-wrap gap-2">
        {stack.map(item => (
          <span
            class="font-mono text-xs px-3 py-1.5 rounded-md cursor-default transition-all duration-200"
            style="background: var(--bg-surface); border: var(--border-width) solid var(--border); color: var(--text-secondary);"
            data-tech-tag
          >
            {item}
          </span>
        ))}
      </div>
    </section>

    <section class="mb-16" aria-label="Work experience">
      <h2 class="text-xl font-semibold mb-6 flex items-center gap-2" style="color: var(--text-primary);">
        <span class="font-mono text-sm" style="color: var(--accent-from);" aria-hidden="true">~/</span>
        Experience
      </h2>
      <div class="space-y-4">
        {experience.map(exp => (
          <ExperienceCard
            company={exp.company}
            role={exp.role}
            period={exp.period}
            achievements={exp.achievements.map(text => ({ text }))}
            tech={exp.tech}
          />
        ))}
      </div>
    </section>

    <AIDesignProcess />

    <EngineeringLog />

    <GitTree />

    <div class="mb-16">
      <About />
    </div>

    <footer class="border-t pt-8" style="border-color: var(--border);" role="contentinfo">
      <p class="font-mono text-xs text-center" style="color: var(--text-secondary);">
        © {currentYear} {meta.name} · Built with Astro 4 + Tailwind CSS
      </p>
    </footer>

  </div>

  <PrintButton />

</BaseLayout>
